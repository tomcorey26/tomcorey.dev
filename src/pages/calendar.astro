---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

// Paste the iframe `src` from Google Calendar:
//   Settings → your calendar → "Integrate calendar" → "Public URL to this calendar"
// First set Access permissions → "Make available to public" → "See only free/busy (hide details)"
// so event titles / locations / descriptions stay hidden.
const CALENDAR_EMBED_URL =
  "https://calendar.google.com/calendar/embed?height=600&wkst=1&ctz=America%2FNew_York&showPrint=0&mode=WEEK&showNav=0&showDate=0&showTabs=0&showCalendars=0&title=Tom's%20Schedule&src=dG9tYmNvcmV5QGdtYWlsLmNvbQ&src=ZW4udXNhI2hvbGlkYXlAZ3JvdXAudi5jYWxlbmRhci5nb29nbGUuY29t&src=dDQ0ajFuM2MwaGN0azU0bzY5MHZsdDVrM2JwM2IxMmVAaW1wb3J0LmNhbGVuZGFyLmdvb2dsZS5jb20&color=%23039be5&color=%230b8043&color=%23ef6c00";
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <BaseHead title="Calendar" description="Schedule" />
    <meta name="robots" content="noindex, nofollow" />
    <style>
      main {
        max-width: 1100px;
        margin: 0 auto;
        padding: 2.5rem 1.5rem 3rem;
        animation: page-fade-in 0.6s ease-out both;
      }
      @keyframes page-fade-in {
        0% {
          opacity: 0;
          transform: translateY(14px);
        }
        100% {
          opacity: 1;
          transform: translateY(0);
        }
      }
      h1 {
        font-family: "Space Grotesk", "Inter", system-ui, sans-serif;
        font-size: clamp(1.8rem, 4vw, 2.4rem);
        letter-spacing: -0.02em;
        margin: 0 0 1.25rem;
        color: var(--text-primary);
      }
      .calendar-frame {
        border-radius: 12px;
        overflow: hidden;
        border: 1px solid var(--border);
        background: rgba(255, 255, 255, 0.02);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.25);
      }
      .calendar-frame iframe {
        display: block;
        width: 100%;
        height: 720px;
        border: 0;
      }
      @media (max-width: 640px) {
        .calendar-frame iframe {
          height: 560px;
        }
      }
      @media (prefers-reduced-motion: reduce) {
        main {
          animation: none;
        }
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <h1>Calendar</h1>
      <div class="calendar-frame">
        <iframe
          src={CALENDAR_EMBED_URL}
          title="Google Calendar"
          scrolling="no"
          loading="lazy"
        ></iframe>
      </div>
    </main>
    <Footer />
  </body>
</html>
