---
import BaseHead from '../components/BaseHead.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const credits = {
  'Jukan Tateisi': {
    profileUrl:
      'https://unsplash.com/@tateisimikito?utm_source=unsplash&utm_medium=referral&utm_content=creditCopyText',
    imgUrl:
      'https://unsplash.com/photos/bJhT_8nbUA0?utm_source=unsplash&utm_medium=referral&utm_content=creditCopyText',
  },
};

interface Props {
  frontmatter?: {
    title: string;
    description: string;
    pubDate?: string | Date;
    updatedDate?: string | Date;
    heroImage?: string;
    imgCredit?: keyof typeof credits;
    imgAlt?: string;
  };
}

const props = Astro.props.frontmatter ?? Astro.props;
const { title, description, pubDate, updatedDate, heroImage, imgAlt, imgCredit } = props as any;
---

<html lang="en">
  <head>
    <BaseHead title={title} description={description} image={heroImage} />
    <style>
      .title {
        font-size: 2em;
        margin: 0.25em 0 0;
        color: var(--accent);
        text-shadow: 0 0 10px var(--accent-glow);
      }
      hr {
        border: none;
        border-top: 1px solid var(--border);
        margin: 1rem 0;
      }
      .hero-image {
        max-width: 400px;
        height: auto;
        display: block;
        margin: 0 0 2rem 0;
        object-fit: cover;
        border: 2px solid var(--accent-dim);
        border-radius: 0;
      }
      time {
        color: var(--text-muted);
        text-transform: uppercase;
        font-size: 0.9rem;
      }
      .credit-link {
        color: var(--accent);
      }
    </style>
  </head>

  <body>
    <Header />
    <main>
      <article>
        {
          heroImage && (
            <img class="hero-image" src={heroImage} alt={imgAlt} />
          )
        }
        {
          imgCredit && (
            <div>
              Photo by{' '}
              <a class="credit-link" target="_blank" href={credits[imgCredit]?.profileUrl}>
                {imgCredit}
              </a>{' '}
              on{' '}
              <a class="credit-link" target="_blank" href={credits[imgCredit]?.imgUrl}>
                Unsplash
              </a>
            </div>
          )
        }

        <h1 class="title">{title}</h1>
        {pubDate && <time>{pubDate instanceof Date ? pubDate.toLocaleDateString('en-us', { year: 'numeric', month: 'short', day: 'numeric' }) : pubDate}</time>}
        {
          updatedDate && (
            <div>
              Last updated on <time>{updatedDate instanceof Date ? updatedDate.toLocaleDateString('en-us', { year: 'numeric', month: 'short', day: 'numeric' }) : updatedDate}</time>
            </div>
          )
        }
        <hr />
        <slot />
      </article>
    </main>
    <Footer />
  </body>
</html>
