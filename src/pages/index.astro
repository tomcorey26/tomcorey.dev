---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../config";
import { Dialog } from "../components/Dialog";
import { Card } from "../components/Card";
import JobExperience from "../components/JobExperience";
import Projects from "../components/Projects.astro";

const firstJobStart = new Date("2020-01-01");
const yearsOfExperience = Math.floor(
  (Date.now() - firstJobStart.getTime()) / (1000 * 60 * 60 * 24 * 365.25)
);

const jobs: JobExperience[] = [
  {
    title: "Full-Stack Software Engineer",
    company: "DealerOn",
    companyUrl: "https://www.dealeron.com/",
    emoji: "🚗",
    logo: "https://media.licdn.com/dms/image/v2/D4E0BAQE0rro_noAHwA/company-logo_100_100/B4EZeyBk_QG4AU-/0/1751038448044/dealeron_inc_logo?e=1758758400&v=beta&t=9DLVRNbAbHuJisAREn8yCxqV8-2CNqpiRNASLBgkXjU",
    startDate: new Date("2020-12-23"),
    points: [
      `Built and shipped a greenfield React application enabling operations teams to self-serve OEM feed configuration, eliminating developer-blocking work and accelerating onboarding of new inventory integrations, with full Playwright test coverage`,

      `Sole frontend owner of the dealer-facing pricing configuration application serving 7,000+ automotive dealerships, controlling vehicle pricing, financing offers, and OEM CTAs across every dealer website on the platform; modernized framework and state management across 100+ components`,

      `Delivered full-stack integrations with 10+ major partners including Ford, GM, and Capital One, working to external partnership deadlines`,

      `Contributed full-stack across a 4-service inventory pipeline processing 200,000+ daily vehicle updates; architected priority queue expansion across 3 microservices and resolved production incidents including a queue storm (25,793 messages) and an Elasticsearch indexer bug affecting 3,876 dealerships`,
    ],
    skills: ["React", "TypeScript", ".NET", "C#", "RabbitMQ", "Elasticsearch"],
  },
  {
    title: "Software Engineer (Contract)",
    company: "CVS Health",
    companyUrl: "https://www.cvshealth.com/",
    emoji: "🏥",
    logo: "https://media.licdn.com/dms/image/v2/C4E0BAQEhOw_KVli-CQ/company-logo_100_100/company-logo_100_100/0/1669901807779/cvs_health_logo?e=1758758400&v=beta&t=igAalYXweOJbVvykHVkz6Bzb6srgc3mZBFKl-F1ww6M",
    startDate: new Date("2020-10-01"),
    endDate: new Date("2020-12-20"),
    points: [
      "Built a TypeScript/React tool for automated API proxy generation on Google Cloud's Apigee platform, supporting public CVS Health API infrastructure",
    ],
    skills: ["TypeScript", "React", "Node.js"],
  },
  {
    title: "Software Engineer",
    company: "Maverick Investment Technologies",
    companyUrl: "https://www.linkedin.com/company/maverick-investment-tech/",
    emoji: "📈",
    logo: "https://media.licdn.com/dms/image/v2/C4D0BAQET0W6apKlh9Q/company-logo_100_100/company-logo_100_100/0/1630521649519/maverick_investment_tech_logo?e=1758758400&v=beta&t=5w8-3djs2yQDjORC_e8QEuiLaiLLdDMqMLPwVN7Ebx0",
    startDate: new Date("2020-01-01"),
    endDate: new Date("2020-10-01"),
    points: [
      "Developed a React-based financial analysis platform with real-time stock data visualization and PHP REST API integration",
    ],
    skills: ["React", "JavaScript", "PHP", "PostgreSQL"],
  },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <div class="bg-fx" aria-hidden="true">
      <div class="aurora"></div>
      <canvas id="hero-canvas"></canvas>
    </div>

    <Header title={SITE_TITLE} />

    <main>
      <section class="hero">
        <Card className="introduction">
          <img
            class="portrait"
            src="tom.jpg"
            alt="Tom Corey"
            width="360"
            height="480"
            decoding="async"
          />
          <p class="bio">
            Hey I'm Tom, a full-stack software engineer from Rhode Island with
            {yearsOfExperience}+ years shipping production web applications at
            scale. I'm strong in <strong
              class="role-rotator"
              id="role-rotator"
              data-words="TypeScript,React,Node.js,.NET">TypeScript</strong
            > and modern frontend tooling, with full-stack experience spanning
            distributed systems and external partner integrations.
            <strong
              >I'm currently looking for a new job, so if you're hiring:</strong
            >
          </p>
          <div class="cta-buttons">
            <a
              href="#experience"
              class="cta-link secondary"
              id="view-experience-btn">View My Experience ↓</a
            >
            <a href="mailto:tombcorey@gmail.com" class="cta-link gradient-cta"
              >Shoot Me an Email</a
            >
          </div>
        </Card>
      </section>

      <section id="experience">
        {jobs.map((job) => <JobExperience {...job} />)}
      </section>

      <section id="projects">
        <h2 class="section-heading">Projects</h2>
        <Projects />
      </section>

      <section id="education">
        <h2 class="section-heading">Education</h2>
        <Card>
          <h3 class="education__degree">Bachelor of Computer Science</h3>
          <p class="education__school">The University of Rhode Island</p>
        </Card>
      </section>
    </main>

    <Footer />

    <style>
      .hero {
        text-align: center;
      }

      .portrait {
        width: 180px;
        height: 180px;
        border-radius: 50%;
        display: block;
        margin: 0 auto 1.5rem;
        object-fit: cover;
        object-position: center 80%;
        animation: portrait-load 0.8s ease-out forwards;
        flex-shrink: 0;
      }

      @keyframes portrait-load {
        0% {
          opacity: 0;
          transform: scale(0.8) translateY(20px);
        }
        100% {
          opacity: 1;
          transform: scale(1) translateY(0);
        }
      }

      .bio {
        text-align: center  ;
        font-size: 1.1rem;
        line-height: 1.8;
        max-width: 600px;
        margin: 0 auto;
      }

      .bio strong {
        color: var(--accent-light);
        font-weight: 600;
      }

      .hero a {
        color: white;
      }

      .hero a:hover {
        color: var(--text-primary);
      }

      .cta-link {
        display: inline-block;
        background: var(--accent);
        color: white;
        padding: 0.75rem 1.5rem;
        border: 2px solid transparent;
        border-radius: 6px;
        font-weight: 600;
        text-decoration: none;
        margin-top: 0.5rem;
        box-sizing: border-box;
      }

      .cta-link:hover {
        opacity: 0.9;
        color: white;
      }

      .cta-link.secondary {
        background: transparent;
        border-color: var(--accent);
        color: var(--accent-light);
      }

      .cta-link.secondary:hover {
        background: var(--accent);
        color: white;
      }

      .cta-buttons {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
        margin-top: 1.5rem;
      }

      .gradient-cta {
        background: linear-gradient(
          90deg,
          #667eea,
          #764ba2,
          #f093fb,
          #f5576c,
          #4facfe,
          #667eea
        );
        background-size: 300% 100%;
        animation: gradient-shift 4s ease infinite;
        color: white;
        transition: transform 0.2s ease;
      }

      .gradient-cta:hover {
        animation: gradient-shift 1.5s ease infinite;
        opacity: 1;
        transform: scale(1.05);
      }

      @keyframes gradient-shift {
        0% {
          background-position: 0% 50%;
        }
        50% {
          background-position: 100% 50%;
        }
        100% {
          background-position: 0% 50%;
        }
      }

      .hamster-section {
        max-width: 1000px;
        margin: 3rem auto 2rem;
        padding: 0 2rem;
        text-align: center;
      }

      .section-heading {
        margin: 3rem 0 1rem;
        padding: 0 2rem;
        font-size: clamp(1.6rem, 4vw, 2.2rem);
        color: var(--text-primary);
      }

      .education__degree {
        margin: 0 0 0.25rem;
        color: var(--text-primary);
        font-size: clamp(1.3rem, 3vw, 1.7rem);
      }

      .education__school {
        margin: 0;
        color: var(--text-secondary);
      }

      @media (max-width: 768px) {
        .section-heading {
          padding: 0 1.5rem;
          margin: 2rem 0 0.75rem;
        }
      }

      @media (max-width: 768px) {
        .portrait {
          width: 110px;
          height: 110px;
          margin: 0 auto 1rem;
        }

        .bio {
          font-size: 1.05rem;
          line-height: 1.65;
          padding: 0 0.25rem;
        }

        .hero a {
          font-size: 1rem;
        }

        .cta-buttons {
          flex-direction: column;
          gap: 0.5rem;
          margin-top: 1rem;
          max-width: 320px;
          margin-left: auto;
          margin-right: auto;
        }

        .cta-link {
          padding: 0.75rem 1rem;
          font-size: 1rem;
          width: 100%;
          text-align: center;
        }

        .hamster-section {
          padding: 0 1rem;
          margin: 2rem auto 1rem;
        }
      }

      @media (max-width: 480px), (max-width: 768px) and (max-height: 740px) {
        .portrait {
          width: 88px;
          height: 88px;
          margin: 0 auto 0.75rem;
        }

        .bio {
          font-size: 0.95rem;
          line-height: 1.55;
          padding: 0;
        }

        .cta-buttons {
          margin-top: 0.75rem;
        }

        .cta-link {
          padding: 0.65rem 1rem;
          font-size: 0.95rem;
        }
      }

      /* --- Background FX --- */
      .bg-fx {
        position: fixed;
        inset: 0;
        z-index: 0;
        pointer-events: none;
      }
      #hero-canvas {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        opacity: 0;
        transition: opacity 1.2s ease;
      }
      #hero-canvas.ready {
        opacity: 1;
      }
      .aurora {
        position: absolute;
        inset: 0;
        background:
          radial-gradient(
            40% 50% at 20% 20%,
            rgba(99, 102, 241, 0.22),
            transparent 70%
          ),
          radial-gradient(
            45% 55% at 80% 25%,
            rgba(192, 132, 252, 0.18),
            transparent 70%
          ),
          radial-gradient(
            50% 60% at 50% 90%,
            rgba(129, 140, 248, 0.16),
            transparent 70%
          );
        filter: blur(20px);
        animation: aurora-drift 18s ease-in-out infinite alternate;
      }
      @keyframes aurora-drift {
        0% {
          transform: translate3d(-2%, -1%, 0) scale(1);
        }
        100% {
          transform: translate3d(2%, 2%, 0) scale(1.08);
        }
      }

      /* --- Gradient section heading underline --- */
      .section-heading {
        position: relative;
        width: fit-content;
      }
      .section-heading::after {
        content: "";
        display: block;
        width: 64px;
        height: 4px;
        margin-top: 0.5rem;
        border-radius: 999px;
        background: linear-gradient(90deg, #818cf8, #c084fc, #f0abfc);
      }

      /* --- Role word rotator --- */
      .role-rotator {
        display: inline-block;
        transition: opacity 0.25s ease, transform 0.25s ease;
        will-change: opacity, transform;
      }
      .role-rotator.swapping {
        opacity: 0;
        transform: translateY(-6px);
      }

      /* --- Portrait tilt --- */
      .portrait {
        transition: transform 0.2s ease;
        will-change: transform;
      }

      /* --- Scroll reveal --- */
      [data-reveal] {
        opacity: 0;
        transform: translateY(28px);
      }
      [data-reveal].is-visible {
        opacity: 1;
        transform: none;
        transition: opacity 0.7s ease, transform 0.7s ease;
      }

      @media (prefers-reduced-motion: reduce) {
        .aurora,
        #hero-canvas {
          animation: none;
        }
        .role-rotator,
        .portrait {
          transition: none;
        }
        [data-reveal] {
          opacity: 1;
          transform: none;
        }
      }
    </style>

    <script>
      import type { HeroBg } from "../scripts/heroBackground";

      const reduceMotion = window.matchMedia(
        "(prefers-reduced-motion: reduce)"
      ).matches;

      let heroBg: HeroBg | null = null;
      let rotatorTimer: number | undefined;

      function initExperienceButton() {
        document
          .getElementById("view-experience-btn")
          ?.addEventListener("click", (e) => {
            e.preventDefault();
            document
              .getElementById("experience")
              ?.scrollIntoView({ behavior: "smooth" });
          });
      }

      function initRoleRotator() {
        const el = document.getElementById("role-rotator");
        if (!el || reduceMotion) return;
        const words = (el.dataset.words || "").split(",").filter(Boolean);
        if (words.length < 2) return;
        let i = 0;
        rotatorTimer = window.setInterval(() => {
          el.classList.add("swapping");
          window.setTimeout(() => {
            i = (i + 1) % words.length;
            el.textContent = words[i];
            el.classList.remove("swapping");
          }, 260);
        }, 2400);
      }

      function initPortraitTilt() {
        const img = document.querySelector<HTMLElement>(".portrait");
        if (!img || reduceMotion) return;
        const onMove = (e: PointerEvent) => {
          const r = img.getBoundingClientRect();
          const px = (e.clientX - r.left) / r.width - 0.5;
          const py = (e.clientY - r.top) / r.height - 0.5;
          img.style.transform = `perspective(600px) rotateY(${
            px * 12
          }deg) rotateX(${-py * 12}deg) scale(1.04)`;
        };
        const reset = () => {
          img.style.transform = "";
        };
        img.addEventListener("pointermove", onMove);
        img.addEventListener("pointerleave", reset);
      }

      function initScrollReveal() {
        const cards = document.querySelectorAll(
          "#experience .card, #projects .card, #education .card"
        );
        if (reduceMotion || !("IntersectionObserver" in window)) {
          cards.forEach((c) => c.classList.add("is-visible"));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            entries.forEach((entry) => {
              if (entry.isIntersecting) {
                entry.target.classList.add("is-visible");
                io.unobserve(entry.target);
              }
            });
          },
          { threshold: 0.12, rootMargin: "0px 0px -8% 0px" }
        );
        cards.forEach((c) => {
          c.setAttribute("data-reveal", "");
          io.observe(c);
        });
      }

      function initHeroBg() {
        const canvas = document.getElementById(
          "hero-canvas"
        ) as HTMLCanvasElement | null;
        if (!canvas || reduceMotion) return;
        const load = () =>
          import("../scripts/heroBackground").then(
            ({ initHeroBackground }) => {
              if (!document.body.contains(canvas)) return;
              heroBg = initHeroBackground(canvas);
              canvas.classList.add("ready");
            }
          );
        if ("requestIdleCallback" in window) {
          (window as any).requestIdleCallback(load, { timeout: 2000 });
        } else {
          window.setTimeout(load, 600);
        }
      }

      function teardown() {
        heroBg?.dispose();
        heroBg = null;
        if (rotatorTimer) window.clearInterval(rotatorTimer);
      }

      function setup() {
        teardown();
        initExperienceButton();
        initRoleRotator();
        initPortraitTilt();
        initScrollReveal();
        initHeroBg();
      }

      // With <ClientRouter />, astro:page-load fires on the initial load and
      // after every client-side navigation. setup() is idempotent (it calls
      // teardown() first), so binding only to these two events is safe.
      document.addEventListener("astro:page-load", setup);
      document.addEventListener("astro:before-swap", teardown);
    </script>
  </body>
</html>
