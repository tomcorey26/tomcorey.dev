---
import BaseHead from "../components/BaseHead.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import { SITE_TITLE, SITE_DESCRIPTION } from "../config";
import { Dialog } from "../components/Dialog";
import { Card } from "../components/Card";
import JobExperience from "../components/JobExperience";

const firstJobStart = new Date("2020-01-01");
const yearsOfExperience = Math.floor(
  (Date.now() - firstJobStart.getTime()) / (1000 * 60 * 60 * 24 * 365.25)
);

const jobs: JobExperience[] = [
  {
    title: "Software Engineer",
    company: "DealerOn",
    companyUrl: "https://www.dealeron.com/",
    emoji: "🚗",
    startDate: new Date("2020-12-23"),
    points: [
      `Lead UI development for the inventory team and develop full-stack solutions within a cross-functional agile environment`,

      `Build frontend applications using React, Vue, and TypeScript, alongside backend systems in .NET/C#/Azure, serving 7,000+ automotive dealerships through a high-traffic web platform that processes millions of requests hourly`,

      `Redesigned and rebuilt a customer-facing vehicle pricing configuration system using Vue.js and .NET APIs, resulting in a 20% reduction in pricing-related support tickets through enhanced UI validation and automated workflows`,

      `Maintain and enhance a robust inventory management platform featuring RabbitMQ-based microservices that consume data from major OEM vendors (Ford, Toyota, GM, and others), processing over 200,000 daily inventory updates`,

      `Developed a comprehensive export data UI system with seamless integration across 15+ third-party automotive platforms, including CarFax, Google Vehicle Ads, and various OEM-specific inventory feeds`,
    ],
    skills: [
      "React",
      "Vue",
      "TypeScript",
      ".NET",
      "C#",
      "Azure",
      "Elasticsearch",
      "RabbitMQ",
    ],
  },
  {
    title: "Software Engineer",
    company: "CVS Health",
    companyUrl: "https://www.cvshealth.com/",
    emoji: "🏥",
    startDate: new Date("2020-10-01"),
    endDate: new Date("2020-12-20"),
    points: [
      "Worked on a SAFe Agile team delivering solutions for the public CVS Health RESTful API",

      "Utilized TypeScript, React, and Node to create a tool for the generation of API proxies on Google Cloud's Apigee platform",
    ],
    skills: ["TypeScript", "React", "Node.js"],
  },
  {
    title: "Full Stack Software Engineer",
    company: "Maverick Investment Tech",
    companyUrl: "https://www.linkedin.com/company/maverick-investment-tech/",
    emoji: "📈",
    startDate: new Date("2020-01-01"),
    endDate: new Date("2020-10-01"),
    points: [
      "Worked on an interactive tool to retrieve and visualize stock data for financial analysis using React",

      "Developed a PHP RESTful API to import external stock information from a PostgreSQL datastore",
    ],
    skills: ["JavaScript", "React", "PHP", "PostgreSQL"],
  },
];
---

<!DOCTYPE html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header title={SITE_TITLE} />

    <main>
      <Card className="introduction">
        <img class="portrait" src="tom.jpg" alt="Tom Corey" />
        <p>
          Hey I'm Tom, a full-stack software engineer from Rhode Island with
          {yearsOfExperience}+ years of experience specializing in <strong
            >React, Vue, TypeScript, Node.js, and .NET</strong
          >. I have extensive experience building enterprise-scale applications
          in cross-functional agile environments, delivering high-performance
          solutions that serve thousands of users and process millions of
          requests.
          <strong
            >I'm currently looking for a new job, so if you're hiring:</strong
          >
        </p>
        <div class="cta-buttons">
          <a
            href="#experience"
            class="cta-link secondary"
            id="view-experience-btn">View My Experience</a
          >
          <a href="mailto:tombcorey@gmail.com" class="cta-link primary"
            >Shoot Me an Email</a
          >
        </div>
      </Card>

      <section id="experience">
        {jobs.map((job) => <JobExperience {...job} />)}
      </section>
    </main>

    <Footer />

    <style>
      .introduction {
        text-align: center;
      }

      .portrait {
        width: 180px;
        height: 180px;
        border-radius: 8px;
        display: block;
        margin: 0 auto 1.5rem;
        object-fit: cover;
        object-position: center 80%;
        border: 2px solid var(--accent);
        outline: 2px solid var(--accent-dim);
        outline-offset: 3px;
        box-shadow: inset 0 0 15px rgba(0, 0, 0, 0.5), 0 0 15px var(--accent-glow);
        animation: portrait-load 0.6s ease-out forwards;
      }

      @keyframes portrait-load {
        0% {
          opacity: 0;
        }
        100% {
          opacity: 1;
        }
      }

      .introduction p {
        font-size: 1rem;
        line-height: 1.8;
        max-width: 600px;
        margin: 0 auto;
      }

      .introduction strong {
        color: var(--accent);
      }

      .cta-buttons {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
        margin-top: 1.5rem;
      }

      .cta-link {
        display: inline-block;
        padding: 0.75rem 1.5rem;
        font-family: "Share Tech Mono", monospace;
        font-size: 1rem;
        text-decoration: none;
        text-transform: uppercase;
        letter-spacing: 0.05em;
      }

      .cta-link.primary {
        background: linear-gradient(180deg, #cc8e00 0%, #aa7500 50%, #886000 100%);
        color: var(--primary);
        border: 2px outset #cc8e00;
      }

      .cta-link.primary:hover {
        background: linear-gradient(180deg, #ffb000 0%, #cc8e00 50%, #aa7500 100%);
        border-color: #ffb000;
      }

      .cta-link.secondary {
        background: transparent;
        border: 2px solid var(--accent-dim);
        color: var(--accent);
      }

      .cta-link.secondary:hover {
        border-color: var(--accent);
        text-shadow: 0 0 8px var(--accent-glow);
      }

      @media (max-width: 768px) {
        .portrait {
          width: 140px;
          height: 140px;
        }

        .introduction p {
          font-size: 0.95rem;
          padding: 0 1rem;
        }

        .cta-buttons {
          flex-direction: column;
          gap: 0.75rem;
        }

        .cta-link {
          padding: 1rem 2rem;
          width: 100%;
          text-align: center;
        }
      }
    </style>

    <script>
      document
        .getElementById("view-experience-btn")
        ?.addEventListener("click", (e) => {
          e.preventDefault();
          document
            .getElementById("experience")
            ?.scrollIntoView({ behavior: "smooth" });
        });
    </script>
  </body>
</html>
