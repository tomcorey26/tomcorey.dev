---
import HeaderLink from "./HeaderLink.astro";
import { SITE_TITLE } from "../config";
---

<header>
  <div class="header-container">
    <div class="header-top">
      <h2>
        {SITE_TITLE}
      </h2>
      <button class="hamburger" id="hamburger" aria-label="Toggle menu">
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
        <span class="hamburger-line"></span>
      </button>
    </div>
    <nav id="nav">
      <HeaderLink href="/">Home</HeaderLink>
      <HeaderLink href="/blog">Blog</HeaderLink>
      <HeaderLink href="/about">About</HeaderLink>
      <HeaderLink
        href="https://www.linkedin.com/in/tom-corey-499419170/"
        target="_blank"
      >
        Linkedin
      </HeaderLink>
      <HeaderLink href="https://github.com/tomcorey26" target="_blank">
        GitHub
      </HeaderLink>
    </nav>
  </div>
</header>

<style>
  header {
    margin: 0 0 0.5rem;
    padding: 1rem 0;
  }

  .header-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    position: relative;
  }

  .header-container::after {
    content: "";
    position: absolute;
    bottom: -2rem;
    left: 2rem;
    right: 2rem;
    height: 1px;
    background: var(--accent);
    opacity: 0.3;
  }

  .header-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  h2 {
    margin: 0;
    font-size: clamp(1.5rem, 3vw, 2rem);
    font-weight: 800;
    letter-spacing: -0.5px;
    background: linear-gradient(
      90deg,
      #818cf8,
      #c084fc,
      #f0abfc,
      #818cf8
    );
    background-size: 200% auto;
    -webkit-background-clip: text;
    background-clip: text;
    color: transparent;
    animation: title-shimmer 6s linear infinite;
  }

  @keyframes title-shimmer {
    to {
      background-position: 200% center;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    h2 {
      animation: none;
    }
  }

  .hamburger {
    display: none;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
    z-index: 100;
  }

  .hamburger-line {
    width: 24px;
    height: 2px;
    background: var(--accent-light);
    transition: all 0.3s ease;
  }

  .hamburger.active .hamburger-line:nth-child(1) {
    transform: rotate(45deg) translate(5px, 5px);
  }

  .hamburger.active .hamburger-line:nth-child(2) {
    opacity: 0;
  }

  .hamburger.active .hamburger-line:nth-child(3) {
    transform: rotate(-45deg) translate(5px, -5px);
  }

  nav {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
    margin-top: 1rem;
  }

  @media (max-width: 768px) {
    .header-container {
      padding: 0 1rem;
    }

    .header-container::after {
      left: 1rem;
      right: 1rem;
    }

    .hamburger {
      display: flex;
    }

    nav {
      display: flex;
      flex-direction: column;
      gap: 0;
      margin-top: 1rem;
      background: var(--surface);
      border-radius: 8px;
      overflow: hidden;
      max-height: 0;
      opacity: 0;
      transform: translateY(-8px);
      pointer-events: none;
      transition: max-height 0.32s ease, opacity 0.25s ease,
        transform 0.32s ease;
    }

    nav.open {
      max-height: 360px;
      opacity: 1;
      transform: translateY(0);
      pointer-events: auto;
    }

    @media (prefers-reduced-motion: reduce) {
      nav {
        transition: none;
      }
    }

    nav :global(a) {
      padding: 0.75rem 1rem;
      border-bottom: 1px solid rgba(255, 255, 255, 0.1);
    }

    nav :global(a:last-child) {
      border-bottom: none;
    }
  }
</style>

<script>
  function initHamburger() {
    const hamburger = document.getElementById("hamburger");
    const nav = document.getElementById("nav");
    if (!hamburger || hamburger.dataset.bound === "1") return;
    hamburger.dataset.bound = "1";
    hamburger.addEventListener("click", () => {
      const open = hamburger.classList.toggle("active");
      nav?.classList.toggle("open", open);
      hamburger.setAttribute("aria-expanded", String(open));
    });
    // Close the menu after navigating via a link
    nav?.addEventListener("click", (e) => {
      if ((e.target as HTMLElement).closest("a")) {
        hamburger.classList.remove("active");
        nav.classList.remove("open");
        hamburger.setAttribute("aria-expanded", "false");
      }
    });
  }
  // With <ClientRouter />, astro:page-load fires on the initial load and
  // after every navigation. The dataset guard keeps binding idempotent.
  document.addEventListener("astro:page-load", initHamburger);
</script>
