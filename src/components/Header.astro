---
import HeaderLink from "./HeaderLink.astro";
import { SITE_TITLE } from "../config";
---

<header>
  <div class="header-container">
    <div class="header-top">
      <h2>
        {SITE_TITLE}
      </h2>
      <button class="menu-toggle" id="hamburger" aria-label="Toggle menu">
        [MENU]
      </button>
    </div>
    <nav id="nav">
      <HeaderLink href="/">Home</HeaderLink>
      <HeaderLink href="/blog">Blog</HeaderLink>
      <HeaderLink href="/about">About</HeaderLink>
      <HeaderLink
        href="https://www.linkedin.com/in/tom-corey-499419170/"
        target="_blank"
      >
        Linkedin
      </HeaderLink>
      <HeaderLink href="https://github.com/tomcorey26" target="_blank">
        GitHub
      </HeaderLink>
    </nav>
  </div>
</header>

<style>
  header {
    margin: 0 0 0.5rem;
    padding: 1rem 0;
  }

  .header-container {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 2rem;
    position: relative;
  }

  .header-container::after {
    content: "";
    position: absolute;
    bottom: -2rem;
    left: 2rem;
    right: 2rem;
    height: 1px;
    background: var(--accent);
    opacity: 0.4;
  }

  .header-top {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  h2 {
    margin: 0;
    font-size: clamp(1.2rem, 3vw, 1.6rem);
    color: var(--accent);
    text-shadow: 0 0 10px var(--accent-glow);
    letter-spacing: 0.1em;
  }

  .menu-toggle {
    display: none;
    background: none;
    border: 1px solid var(--accent);
    color: var(--accent);
    padding: 0.4rem 0.8rem;
    font-family: "Share Tech Mono", monospace;
    font-size: 0.85rem;
    cursor: pointer;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .menu-toggle:hover {
    background: rgba(255, 176, 0, 0.1);
  }

  nav {
    display: flex;
    gap: 0.25rem;
    flex-wrap: wrap;
    margin-top: 1rem;
  }

  @media (max-width: 768px) {
    .header-container {
      padding: 0 1rem;
    }

    .header-container::after {
      left: 1rem;
      right: 1rem;
    }

    .menu-toggle {
      display: block;
    }

    nav {
      display: none;
      flex-direction: column;
      gap: 0;
      margin-top: 1rem;
      background: var(--surface);
      border: 1px solid var(--border);
      overflow: hidden;
    }

    nav.open {
      display: flex;
    }

    nav :global(a) {
      padding: 0.75rem 1rem;
      border-bottom: 1px solid var(--border);
    }

    nav :global(a:last-child) {
      border-bottom: none;
    }
  }
</style>

<script>
  const hamburger = document.getElementById("hamburger");
  const nav = document.getElementById("nav");

  hamburger?.addEventListener("click", () => {
    hamburger.classList.toggle("active");
    nav?.classList.toggle("open");
  });
</script>
